# ── Required ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://aura:aura_secret@localhost:5432/aura_ai
PORT=8080

# ── Clerk Auth ───────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_your-clerk-secret-key
CLERK_PUBLISHABLE_KEY=pk_your-clerk-publishable-key
CLERK_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# ── AI / LLM ──────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
GROQ_API_KEY=gsk-your-groq-api-key

# Model selection (defaults shown — override per environment)
# MODEL_GENERATE_REPLY=llama-3.1-8b-instant
# MODEL_MODERATE_INPUT=meta-llama/llama-prompt-guard-2-86m
# MODEL_MODERATE_OUTPUT=openai/gpt-oss-safeguard-20b
# MODEL_CONSOLIDATE_MEMORY=llama-3.1-8b-instant
# MODEL_FALLBACK_GENERATE_REPLY=llama-3.1-8b-instant
# MODEL_FALLBACK_MODERATE_INPUT=llama-3.3-70b-versatile
# MODEL_FALLBACK_MODERATE_OUTPUT=llama-3.3-70b-versatile
# MODEL_FALLBACK_CONSOLIDATE_MEMORY=llama-3.3-70b-versatile

# ── Payments (RevenueCat) ─────────────────────────────────────────────
REVENUECAT_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# ── APNs ──────────────────────────────────────────────────────────────
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY_FILE=
APNS_ENVIRONMENT=sandbox

# ── Security ──────────────────────────────────────────────────────────
BANNED_IDENTITY_PEPPER=generate-a-strong-random-pepper-here

# ── Monitoring ────────────────────────────────────────────────────────
SENTRY_DSN=
